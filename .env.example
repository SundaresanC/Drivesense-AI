# DriveSense AI Configuration
# Copy this file to .env and fill in your API keys

# ===== FREE LLM Provider (Required for AI features) =====
# Get free API key at: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_free_gemini_api_key_here

# ===== FREE Speech Services (No keys needed) =====
# Uses gTTS (Google Text-to-Speech) - completely FREE
# Uses pyttsx3 (Offline TTS) - completely FREE
# No API keys required!

# ===== Optional: Stream.io (For cloud deployment) =====
# Only needed if deploying to Stream's edge network
STREAM_API_KEY=your_stream_api_key_here
STREAM_API_SECRET=your_stream_api_secret_here

# ===== Optional: Hardware Configuration =====
# Set to 'cuda' for GPU acceleration (requires NVIDIA GPU)
# Set to 'cpu' for CPU-only mode (slower but works everywhere)
DEVICE=cpu
DEVICE=cuda

# ===== Camera Configuration =====
# Camera source (0 for default webcam, or IP camera URL)
CAMERA_SOURCE=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=10
